cd /home/claude && python3 << 'EOF'
import pandas as pd
import sqlite3
import os

# Charger le dataset ACREMAC
df = pd.read_excel("/mnt/user-data/uploads/Dataset_scoring_solvabilite_ACREMAC.xlsx")

print(f"✅ Dataset chargé : {df.shape}")
print(f"   Colonnes : {list(df.columns)}")
print(f"   Types :\n{df.dtypes}")
print(f"\n   Aperçu :\n{df.head(3)}")

# Créer la base SQLite
conn = sqlite3.connect('/home/claude/acremac.db')
cursor = conn.cursor()

# Créer la table clients
cursor.execute("DROP TABLE IF EXISTS clients")
cursor.execute("""
CREATE TABLE clients (
    client_id              TEXT PRIMARY KEY,
    client_type            TEXT,
    age                    INTEGER,
    annual_income          REAL,
    loan_amount            REAL,
    loan_duration_months   INTEGER,
    interest_rate          REAL,
    past_defaults          INTEGER,
    credit_history_years   REAL,
    existing_loans         INTEGER,
    monthly_payment_ratio  REAL,
    collateral_value       REAL,
    sector                 TEXT,
    country                TEXT,
    days_late_avg          REAL,
    solvency_score         REAL
)
""")

# Insérer les données
df.to_sql('clients', conn, if_exists='replace', index=False)

# Vérification
count = cursor.execute("SELECT COUNT(*) FROM clients").fetchone()[0]
sample = cursor.execute("SELECT * FROM clients LIMIT 3").fetchall()
cols = [d[0] for d in cursor.description]

print(f"\n✅ Base SQLite créée : acremac.db")
print(f"   Table 'clients' : {count} enregistrements")
print(f"   Colonnes : {cols}")

# Test requête SQL
result = cursor.execute("""
    SELECT country, COUNT(*) as nb, AVG(solvency_score) as score_moy
    FROM clients
    GROUP BY country
    ORDER BY score_moy DESC
""").fetchall()
print(f"\n✅ Test requête SQL :")
for row in result:
    print(f"   {row[0]} : {row[1]} clients | score moy = {row[2]:.1f}")

conn.close()
print("\n✅ Base SQLite prête !")
EOF
